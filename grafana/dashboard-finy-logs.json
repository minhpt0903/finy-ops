          "tooltip": { "mode": "multi", "sort": "none" }
        },
        "pluginVersion": "10.0.0",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
            "editorMode": "code",
            "expr": "sum by (level) (count_over_time({app=~\"$app\"} [$__interval]))",
            "legendFormat": "{{level}}",
            "queryType": "range",
            "refId": "A"
          }
        ],
        "title": "📊 Logs by Level Over Time",
        "type": "timeseries"
      },
