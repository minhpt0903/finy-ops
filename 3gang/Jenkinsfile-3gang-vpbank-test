pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '7'))
        gitLabConnection('gitlab-finy')
        disableConcurrentBuilds(abortPrevious: true)
        quietPeriod(30)
        gitlabBuilds(builds: ['checkout', 'build', 'deploy'])
    }

    triggers {
        gitlab(
            triggerOnPush: true,
            triggerOnMergeRequest: false,
            triggerOnAcceptedMergeRequest: false,
            branchFilterType: 'NameBasedFilter',
            includeBranchesSpec: 'test'
        )
    }

    tools {
        gradle 'Gradle-7.6.4'
        jdk 'JDK-17'
    }

    environment {
        APP_NAME = '3gang-vpbank'
        SPRING_PROFILE = 'test'
        APP_PORT = '9005'
}

    stages {

        stage('Checkout') {
            steps {
                script {
                    echo "=========================================="
                    echo "Build Configuration:"
                    echo "  Environment: test"
                    echo "  Git Branch: test"
                    echo "  Spring Profile: ${SPRING_PROFILE}"
                    echo "  Application Port: ${APP_PORT}"
                    echo "=========================================="
                }
                git branch: 'test',
                    url: "https://gitlab.finy.vn/3gang/vpbank-consumer.git",
                    credentialsId: 'gitlab-finy-credentials'
            }
        }

        stage('Build') {
            steps {
                script {
                    echo "Building Spring Boot application for test environment"
                    echo "Using Spring Profile: ${SPRING_PROFILE}"
                }
                sh 'gradle --version'
                sh '''
                    gradle clean bootJar \
                        -Pspring.profiles.active=${SPRING_PROFILE} \
                        --no-daemon
                '''
            }
        }

        stage('Build Image') {
            steps {
                script {
                    echo "=========================================="
                    echo "Transferring and building image on lb-test-01..."
                    echo "Image: ${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER}"
                    echo "=========================================="
                }
                sh '''
                    ssh jen@lb-test-01 "mkdir -p /tmp/${APP_NAME}-build/build/libs"
                    scp build/libs/*.jar jen@lb-test-01:/tmp/${APP_NAME}-build/build/libs/
                    scp Dockerfile jen@lb-test-01:/tmp/${APP_NAME}-build/
                    ssh jen@lb-test-01 bash << BUILDSSH
set -e
sudo podman build \
    -t localhost/${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER} \
    -t localhost/${APP_NAME}:${SPRING_PROFILE}-latest \
    /tmp/${APP_NAME}-build/
rm -rf /tmp/${APP_NAME}-build
echo "Image built: localhost/${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER}"
BUILDSSH
                '''
                script {
                    echo "✅ Image built on lb-test-01: ${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER}"
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    def imageTag = "${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER}"
                    def containerName = "${APP_NAME}-${SPRING_PROFILE}"
                    echo "=========================================="
                    echo "Deploying to test environment"
                    echo "Spring Profile: ${SPRING_PROFILE}"
                    echo "Container: ${containerName}"
                    echo "Port: ${APP_PORT}:9019"
                    echo "=========================================="
                }
                withCredentials([
                    usernamePassword(
                        credentialsId: '3gang-db-test',
                        usernameVariable: 'DB_USER',
                        passwordVariable: 'DB_PASS'
                    )
                ]) {
                    sh '''
                        set -e
                        echo "Deploying on remote server..."
                        ssh jen@lb-test-01 bash << ENDSSH
sudo podman stop ${APP_NAME}-${SPRING_PROFILE} 2>/dev/null || true
sudo podman rm ${APP_NAME}-${SPRING_PROFILE} 2>/dev/null || true
sudo podman run -d --name ${APP_NAME}-${SPRING_PROFILE} \\
    --network finy-net \\
    -e SPRING_PROFILES_ACTIVE=${SPRING_PROFILE} \\
    -e SPRING_DATASOURCE_URL="jdbc:oracle:thin:@//172.16.10.101:1521/LB" \\
    -e SPRING_DATASOURCE_USERNAME="${DB_USER}" \\
    -e SPRING_DATASOURCE_PASSWORD="${DB_PASS}" \\
    -e SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092 \\
    -e TZ=Asia/Ho_Chi_Minh \\
    -e LOKI_URL=http://loki:3100/loki/api/v1/push \\
    -e APP_NAME=${APP_NAME} \\
    -e VPS_NAME=test-server \\
    -e LOG_PATH=/logs \\
    -p ${APP_PORT}:9019 \\
    -v /home/3gang-services/vpbank/logs:/logs:Z \\
    --restart unless-stopped \\
    localhost/${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER}
sleep 10
sudo podman logs --tail 30 ${APP_NAME}-${SPRING_PROFILE}
ENDSSH
                    '''
                }
                script {
                    echo "✅ TEST deployed via SSH to lb-test-01"
                    echo "=========================================="
                    echo "✅ Deployment completed!"
                    echo "Application URL: http://lb-test-01:${APP_PORT}"
                    echo "Container: ${APP_NAME}-${SPRING_PROFILE}"
                    echo "Image: ${APP_NAME}:${SPRING_PROFILE}-${BUILD_NUMBER}"
                    echo ""
                    echo "  View logs: ssh jen@lb-test-01 sudo podman logs -f ${APP_NAME}-${SPRING_PROFILE}"
                    echo "  Stop:      ssh jen@lb-test-01 sudo podman stop ${APP_NAME}-${SPRING_PROFILE}"
                    echo "  Restart:   ssh jen@lb-test-01 sudo podman restart ${APP_NAME}-${SPRING_PROFILE}"
                    echo "=========================================="
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'build/libs/*.jar', fingerprint: true
            }
        }
    }

    post {
        success {
            echo "========================================="
            echo "✓ Build SUCCESS"
            echo "Build: #${BUILD_NUMBER}"
            echo "========================================="
            updateGitlabCommitStatus name: 'deploy', state: 'success'
        }
        failure {
            echo "========================================="
            echo "✗ Build FAILED"
            echo "Build: #${BUILD_NUMBER}"
            echo "========================================="
            updateGitlabCommitStatus name: 'deploy', state: 'failed'
        }
        always {
            cleanWs()
        }
    }
}
